        <mxCell id="note_scope" value="ERD ini dibuat murni dari migration project.&#xa;&#xa;Yang ditampilkan: PK, FK, dan kolom bisnis utama.&#xa;timestamps / softDeletes / snapshot field panjang diringkas agar kanvas tetap terbaca.&#xa;&#xa;Catatan: jika controller/model memakai kolom tambahan yang belum punya migration, kolom itu sengaja tidak dimasukkan." style="shape=note;whiteSpace=wrap;html=0;strokeColor=#d6b656;fillColor=#fff2cc;fontSize=12;align=left;verticalAlign=top;spacing=6;" vertex="1" parent="1">
          <mxGeometry x="3600" y="60" width="520" height="170" as="geometry"/>
        </mxCell>
        <mxCell id="note_morph" value="Relasi polymorphic / non-FK yang penting:&#xa;- notifications.notifiable_type + notifiable_id&#xa;- model_has_roles.model_type + model_id&#xa;- model_has_permissions.model_type + model_id&#xa;- rekening_bank.pemilik_type + pemilik_id&#xa;- workflow_instances.workflowable_type + workflowable_id&#xa;- log_status_dokumen.dokumen_type + dokumen_id&#xa;- arsip_dokumen.documentable_type + documentable_id&#xa;- sessions.user_id hanya indexed, bukan FK constraint" style="shape=note;whiteSpace=wrap;html=0;strokeColor=#6c8ebf;fillColor=#dae8fc;fontSize=12;align=left;verticalAlign=top;spacing=6;" vertex="1" parent="1">
